{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["DOM", "ES2022"],
    "plugins": [{ "name": "next" }],
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@mdas/canonical": ["../../packages/canonical/src/index.ts"],
      "@mdas/scoring": ["../../packages/scoring/src/index.ts"],
      "@mdas/forecast-generator": ["../../packages/forecast-generator/src/index.ts"],
      "@mdas/renewal-metrics": ["../../packages/renewal-metrics/src/index.ts"],
      "@mdas/cta-engine": ["../../packages/cta-engine/src/index.ts"],
      "@mdas/account-plan-engine": ["../../packages/account-plan-engine/src/index.ts"],
      "@mdas/cse-activity": ["../../packages/cse-activity/src/index.ts"],
      "@mdas/db": ["../../packages/db/src/index.ts"],
      "@mdas/slack-send": ["../../packages/slack-send/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
