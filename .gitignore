node_modules
.next
dist
.DS_Store
.env
.env.*
!.env.example
# Glean OAuth state: cached DCR client_id, refresh_token, endpoint
# metadata. Written by scripts/glean-login.mjs, read by
# scripts/glean-refresh.mjs. Contains refresh_token — treat as a
# credential and never commit.
.glean-oauth.json
*.log
coverage
playwright-report
test-results
.lighthouseci
# Salesforce CLI local state — never commit. Auth tokens and sf project
# scratchpad are per-developer.
.sfdx/
.sf/
# Per-developer corporate root CA bundle, exported from the host
# keychain to make Zscaler-intercepted TLS work inside docker
# containers. See README "Corporate TLS interception" section.
.docker-ca.pem
# Cascade-relay bridge fixture — contains real customer ARR / sentiment
# / sentiment commentary pulled from Glean salescloud. Never commit.
# See scripts/import-cascade-bridge.ts.
seed/cascade-bridge.json
# Slack channel sweep: persistent Playwright profile (your Slack session
# cookies live here after first SSO login). Treat as a credential —
# never commit. See scripts/sweep-slack-channels.mts.
.playwright-profile-slack/
# Output of the Slack channel sweep. Contains every cust-* channel
# name and id the operator's Slack session can see. Not secret per se,
# but operator-scoped, so don't commit.
data/slack-channels.json

# tsc --incremental build cache — per-developer, never commit
**/*.tsbuildinfo
**/*.d.ts
**/*.d.ts.map
**/*.js
!**/dist/**/*.js
