{
  "name": "mdas",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/adapters/read/*",
    "packages/adapters/mock"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:worker": "npm run dev --workspace apps/worker",
    "restart": "./restart.sh",
    "stop": "bash scripts/local-dev.sh stop && docker-compose down",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc -b --pretty",
    "ci:guard": "node scripts/ci-guard.mjs",
    "check": "npm run ci:guard && npm run lint && npm test",
    "seed": "node scripts/seed.mjs",
    "migrate": "node scripts/migrate.mjs",
    "sf:fieldmap": "tsx scripts/generate-sfdc-field-map.ts",
    "sf:validate": "tsx scripts/validate-salesforce-schema.ts",
    "cta:generate": "tsx scripts/generate-ctas.ts",
    "cta:dry-run": "tsx scripts/generate-ctas.ts --dry-run",
    "cta:backfill": "tsx scripts/backfill-cta-opportunity-ids.ts",
    "cta:triage": "tsx scripts/cta-open-triage.ts",
    "snapshot:prune-expand3": "tsx scripts/prune-expand3-snapshot.ts",
    "snapshot:compact-source-links": "tsx scripts/compact-snapshot-source-links.ts",
    "snapshot:backfill-trajectory-kpis": "tsx scripts/backfill-trajectory-kpis.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "sweep:slack": "tsx scripts/sweep-slack-channels.mts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "pg": "^8.11.5"
  }
}
