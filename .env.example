DATABASE_URL=postgres://mdas:mdas@localhost:5432/mdas
ADAPTER_SALESFORCE=mock
ADAPTER_CEREBRO=mock
ADAPTER_GAINSIGHT=mock
ADAPTER_STAIRCASE=mock
ADAPTER_ZUORA_MCP=mock
ADAPTER_GLEAN_MCP=mock

# PR-B3 / F-17: per-adapter timeout, in milliseconds.
# Global default 25000. Override per source by suffixing the source name
# in upper-case-snake (e.g. ADAPTER_TIMEOUT_MS_GLEAN_MCP=60000 for the
# slower Glean MCP cold path). Hyphens in source names become underscores.
# ADAPTER_TIMEOUT_MS=25000
# ADAPTER_TIMEOUT_MS_GLEAN_MCP=60000

# Real adapter secrets (leave blank for mock-only run)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=
SALESFORCE_INSTANCE_URL=
ZUORA_MCP_CLIENT_ID=
ZUORA_MCP_CLIENT_SECRET=
ZUORA_MCP_BASE_URL=https://apisandbox.zuora.com/mcp
GLEAN_MCP_TOKEN=
GLEAN_MCP_BASE_URL=
GAINSIGHT_GLEAN_CONNECTOR=true

# In-app Glean auth posture for the Next.js web app.
# - none (default): single-user / localhost. The /api/glean/* routes
#   reuse GLEAN_MCP_TOKEN above (the same bearer the worker uses) and
#   never expose it to the browser. Results respect that token's Glean
#   permissions.
# - okta: per-user OAuth via Okta. Currently a SCAFFOLD ONLY — the
#   /api/glean/* routes will return HTTP 501 with an admin checklist
#   until Okta + Glean admins complete the prerequisites in
#   docs/integrations/glean.md ("Option B").
AUTH_MODE=none

# Required only when AUTH_MODE=okta (and the admin checklist is done):
# OKTA_ISSUER=https://yourtenant.okta.com
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# NEXTAUTH_SECRET=    # `openssl rand -hex 32`
# NEXTAUTH_URL=http://localhost:3000

# Scoring
SCORING_VERSION=v0.1.0
