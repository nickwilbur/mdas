DATABASE_URL=postgres://mdas:mdas@localhost:5432/mdas
ADAPTER_SALESFORCE=mock
ADAPTER_CEREBRO=mock
ADAPTER_GAINSIGHT=mock
ADAPTER_STAIRCASE=mock
ADAPTER_ZUORA_MCP=mock
ADAPTER_GLEAN_MCP=mock

# PR-B3 / F-17: per-adapter timeout, in milliseconds.
# Global default 25000. Override per source by suffixing the source name
# in upper-case-snake (e.g. ADAPTER_TIMEOUT_MS_GLEAN_MCP=60000 for the
# slower Glean MCP cold path). Hyphens in source names become underscores.
# ADAPTER_TIMEOUT_MS=25000
#
# Glean-using adapters (cerebro, gainsight, glean-mcp) loop over every
# account at concurrency 2 and call Glean's MCP search tool for each.
# At ~700ms/call after rate-limit backoff, 300 accounts ≈ 105s per
# adapter. We default the timeout at 300s so per-account loops can
# finish even with retry pressure.
ADAPTER_TIMEOUT_MS_CEREBRO=300000
ADAPTER_TIMEOUT_MS_GAINSIGHT=300000
ADAPTER_TIMEOUT_MS_GLEAN_MCP=300000

# Real adapter secrets (leave blank for mock-only run)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=
SALESFORCE_INSTANCE_URL=
ZUORA_MCP_CLIENT_ID=
ZUORA_MCP_CLIENT_SECRET=
ZUORA_MCP_BASE_URL=https://apisandbox.zuora.com/mcp
GLEAN_MCP_TOKEN=
GLEAN_MCP_BASE_URL=
GAINSIGHT_GLEAN_CONNECTOR=true

# In-app Glean auth posture for the Next.js web app.
# - none (default): single-user / localhost. The /api/glean/* routes
#   reuse GLEAN_MCP_TOKEN above (the same bearer the worker uses) and
#   never expose it to the browser. Results respect that token's Glean
#   permissions.
# - okta: per-user OAuth via Okta. Currently a SCAFFOLD ONLY — the
#   /api/glean/* routes will return HTTP 501 with an admin checklist
#   until Okta + Glean admins complete the prerequisites in
#   docs/integrations/glean.md ("Option B").
AUTH_MODE=none

# Required only when AUTH_MODE=okta (and the admin checklist is done):
# OKTA_ISSUER=https://yourtenant.okta.com
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# NEXTAUTH_SECRET=    # `openssl rand -hex 32`
# NEXTAUTH_URL=http://localhost:3000

# Scoring
SCORING_VERSION=v0.1.0

# ---- Customer Slack channel workflow (/admin/slack) ----
#
# Three independent send-gate toggles. ALL must pass for a real send to
# fire; ANY failing one blocks. Defaults are safety-first.
#
# 1. SLACK_READ_ONLY_MODE  — Phase-1a kill switch. When set to "true"
#    (case-insensitive), ALL sends are BLOCKED at the gate regardless of
#    any other config. The bot token (if set) is still used for READ-ONLY
#    Slack API calls (conversations.list, conversations.info, auth.test)
#    so the mapping refresh can validate channel ids and detect dead
#    links. Set to "true" while you're only working on mapping; remove
#    or set to "false" for phase 1b when you're ready to send.
SLACK_READ_ONLY_MODE=true

# 2. ENABLE_SLACK_SEND  — Master send toggle. MUST be the literal "true"
#    (case-insensitive) to permit real chat.postMessage calls. Anything
#    else — unset, "false", "1", "yes" — is OFF. Preview is always
#    allowed; the gate only affects confirm/send.
ENABLE_SLACK_SEND=false

# 3. SLACK_BOT_TOKEN  — xoxb-… bot token. Required for any SEND
#    (chat.postMessage). For phase 1a's read-only mapping it needs ONLY
#    the `channels:read` scope; phase 1b also requires `chat:write`.
#    No channels:join, no groups:read. The token is read-only-safe by
#    virtue of its scope set; the read-only-mode toggle above is
#    belt-and-suspenders on top.
SLACK_BOT_TOKEN=

# 3b. SLACK_USER_TOKEN  — xoxp-… user token. OPTIONAL read-only fallback
#     when a bot install requires admin approval and you need to unblock
#     the mapping work right now. With ONLY a user token set:
#       - conversations.list / conversations.info / auth.test all work
#         (the user can see what they can see — typically the same public
#         channels a bot would).
#       - chat.postMessage is HARD-REJECTED by the send gate, because
#         sends would appear to come from the user personally and the
#         blast radius of a leaked user token is the whole user's access.
#     If both SLACK_BOT_TOKEN and SLACK_USER_TOKEN are set, the bot token
#     wins for read calls. Generate one by creating the same Slack app
#     and adding `channels:read` under "User Token Scopes" (not Bot
#     Token Scopes), then Install to Workspace.
SLACK_USER_TOKEN=

# 3c. SLACK_XOXC_TOKEN + SLACK_XOXD_COOKIE — LAST-RESORT browser-session
#     auth, scraped from your own logged-in Slack web client. Use this
#     ONLY when even user-scoped app installs require admin approval and
#     you need read-only mapping work to proceed for an MVP demo.
#
#     SERIOUS RISKS — read before enabling:
#       1. Against Slack TOS §4 ("only use Slack-provided interfaces").
#          Slack tolerates this for individuals but can revoke any time.
#       2. Visible to your workspace admin in API audit logs. If your
#          SecOps team runs audit queries for xoxc usage, your name
#          shows up. Don't use this if you're about to ask the same
#          admin to approve a sanctioned app.
#       3. Acts as YOU. Anything it touches is attributed to your Slack
#          identity. Sends are HARD-REJECTED by the gate for this reason.
#       4. Blast radius of a leak = your entire Slack access (DMs,
#          private channels, everything you can see). Bot-token leak
#          is bounded to the bot's scopes; xoxc leak is full
#          impersonation. Keep .env out of git at all costs — the app
#          will refuse to boot if it detects .env is git-tracked.
#       5. Machine-locked. Will not work in CI, on a teammate's laptop,
#          or in any hosted deployment. Demo runs on your laptop only.
#       6. Token rotates on Slack session refresh (every few hours on
#          most SSO setups). Expect to re-paste from devtools.
#
#     HOW TO EXTRACT (one-time, when you need the token):
#       a) Open https://zuora.enterprise.slack.com in Chrome/Firefox.
#          Make sure you're logged in.
#       b) Open DevTools → Console. Paste and run:
#              JSON.parse(localStorage.localConfig_v2).teams
#          Find the team object for Zuora; copy its `token` field
#          (starts with `xoxc-`) into SLACK_XOXC_TOKEN below.
#       c) DevTools → Application → Cookies → https://slack.com.
#          Find the cookie named `d` (NOT `d-s`). Copy its Value
#          (starts with `xoxd-`) into SLACK_XOXD_COOKIE below.
#       d) Restart `next dev`. Verify on /admin/slack — the gate panel
#          will show a loud red xoxc warning. If the panel shows
#          "INCOMPLETE", you're missing one of the two values.
#
#     PRECEDENCE: bot > user > xoxc. xoxc is only used when neither of
#     the other tokens is set.
SLACK_XOXC_TOKEN=
SLACK_XOXD_COOKIE=

# Test-to-self target. Either a Slack user id (Uxxx) or a pre-opened DM
# channel id (Dxxx). The "Preview → test-to-self" button in /admin/slack
# routes a copy of the message to this id, prefixed with [TEST MODE].
# Required to use test-to-self mode; not required for customer-channel
# send. Has no effect during phase 1a (SLACK_READ_ONLY_MODE=true).
SLACK_TEST_USER_ID=
